<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ColorPrimary">#2563EB</Color>
    <Color x:Key="ColorPrimaryHover">#1D4ED8</Color>
    <Color x:Key="ColorPrimaryPressed">#1E40AF</Color>
    <Color x:Key="ColorPrimaryLight">#EFF6FF</Color>

    <Color x:Key="ColorAccent">#0F766E</Color>
    <Color x:Key="ColorAccentLight">#CCFBF1</Color>
    <Color x:Key="ColorWarning">#D97706</Color>
    <Color x:Key="ColorWarningLight">#FEF3C7</Color>
    <Color x:Key="ColorDanger">#DC2626</Color>
    <Color x:Key="ColorDangerLight">#FEE2E2</Color>
    <Color x:Key="ColorSuccess">#16A34A</Color>
    <Color x:Key="ColorSuccessLight">#DCFCE7</Color>
    <Color x:Key="ColorInfo">#0284C7</Color>
    <Color x:Key="ColorInfoLight">#E0F2FE</Color>

    <Color x:Key="ColorShell">#111827</Color>
    <Color x:Key="ColorShellRaised">#1F2937</Color>
    <Color x:Key="ColorShellHover">#374151</Color>
    <Color x:Key="ColorAppBackground">#F3F4F6</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorSurfaceMuted">#F9FAFB</Color>
    <Color x:Key="ColorBorder">#E5E7EB</Color>
    <Color x:Key="ColorBorderStrong">#D1D5DB</Color>

    <Color x:Key="ColorTextPrimary">#111827</Color>
    <Color x:Key="ColorTextSecondary">#4B5563</Color>
    <Color x:Key="ColorTextMuted">#6B7280</Color>
    <Color x:Key="ColorTextInverse">#F9FAFB</Color>
    <Color x:Key="ColorTextDisabled">#9CA3AF</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource ColorPrimaryHover}" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource ColorPrimaryPressed}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource ColorPrimaryLight}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource ColorAccentLight}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource ColorWarningLight}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource ColorDangerLight}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource ColorSuccessLight}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource ColorInfo}" />
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource ColorInfoLight}" />

    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource ColorShell}" />
    <SolidColorBrush x:Key="SidebarDarkerBrush" Color="{StaticResource ColorShellRaised}" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource ColorShellHover}" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource ColorAppBackground}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="MutedSurfaceBrush" Color="{StaticResource ColorSurfaceMuted}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="StrongBorderBrush" Color="{StaticResource ColorBorderStrong}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource ColorBorder}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource ColorTextInverse}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource ColorTextDisabled}" />

</ResourceDictionary>
