<UserControl x:Class="WIMS.WPF.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource PanelStyle}">
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Operasyon Özeti"
                               Style="{StaticResource HeaderTextStyle}"/>
                    <TextBlock Text="{Binding LastRefreshedText}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Yenile"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding LoadDataCommand}"
                        VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1"
                       Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       Margin="0,16,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <UniformGrid Columns="4">
                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Ürün"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Text="{Binding ProductCount}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Tedarikçi"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Text="{Binding SupplierCount}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Açık Sipariş"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Text="{Binding PendingPurchaseOrderCount}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Stok Değeri"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Text="{Binding TotalStockValueText}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource PanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Düşük Stok"
                                           Style="{StaticResource SubHeaderTextStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LowStockProductCount, StringFormat={}{0} ürün}"
                                           Style="{StaticResource MutedTextStyle}"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding OutOfStockProductCount, StringFormat=Stokta olmayan: {0}}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,4,0,12"/>

                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding LowStockItems}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kod" Binding="{Binding ProductCode}" Width="90"/>
                                    <DataGridTextColumn Header="Ürün" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="Stok" Binding="{Binding CurrentStock}" Width="80"/>
                                    <DataGridTextColumn Header="Birim" Binding="{Binding UnitSymbol}" Width="70"/>
                                    <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Son Stok Hareketleri"
                                       Style="{StaticResource SubHeaderTextStyle}"
                                       Margin="0,0,0,12"/>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding RecentMovements}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tarih" Binding="{Binding MovementDate, StringFormat=dd.MM.yyyy}" Width="95"/>
                                    <DataGridTextColumn Header="Belge" Binding="{Binding DocumentNumber}" Width="90"/>
                                    <DataGridTextColumn Header="Ürün" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="80"/>
                                    <DataGridTextColumn Header="Miktar" Binding="{Binding Quantity}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
