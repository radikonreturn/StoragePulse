<UserControl x:Class="WIMS.WPF.Views.Products.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Ürün kataloğu" Style="{StaticResource SubHeaderTextStyle}"/>
                    <TextBlock Text="Stok kartlarını, birimleri ve kritik seviye bilgilerini yönetin."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <TextBox Grid.Column="1"
                         Style="{StaticResource StandardTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         ToolTip="Ürün adı veya kodu ara"/>

                <Button Grid.Column="3"
                        Content="Yeni ürün"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddProductCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Ürün listesi" Style="{StaticResource SectionTitleTextStyle}"/>
                    <Button Grid.Column="1"
                            Content="Yenile"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding LoadProductsCommand}"/>
                </Grid>

                <Grid Grid.Row="2">
                    <DataGrid
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                          Visibility="{Binding HasProducts, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="120"/>
                            <DataGridTextColumn Header="Ürün adı" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Kategori" Binding="{Binding CategoryName}" Width="150"/>
                            <DataGridTextColumn Header="Birim" Binding="{Binding UnitSymbol}" Width="90"/>
                            <DataGridTextColumn Header="Kritik seviye" Binding="{Binding ReorderPoint}" Width="120"/>
                            <DataGridTextColumn Header="Birim fiyat" Binding="{Binding UnitPrice, StringFormat=N2}" Width="120"/>
                            <DataGridTemplateColumn Header="İşlem" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Düzenle"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="10,4"
                                                    Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,6,0"/>
                                            <Button Content="Sil"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Padding="10,4"
                                                    Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Style="{StaticResource EmptyStateStyle}"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Ürün bulunamadı" Style="{StaticResource EmptyStateTitleTextStyle}"/>
                            <TextBlock Text="Arama ölçütlerini değiştirin veya yeni ürün ekleyin." Style="{StaticResource EmptyStateBodyTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource LoadingOverlayStyle}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Yükleniyor..."
                                   Style="{StaticResource MutedTextStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource ErrorBannerStyle}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
