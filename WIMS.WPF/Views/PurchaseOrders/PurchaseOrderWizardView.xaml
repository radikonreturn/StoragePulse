<UserControl x:Class="WIMS.WPF.Views.PurchaseOrders.PurchaseOrderWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBackgroundBrush}">
    <Grid Margin="28">
        <Border Style="{StaticResource PanelStyle}" MaxWidth="900" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="Sipariş oluşturma" Style="{StaticResource SubHeaderTextStyle}"/>
                    <TextBlock Text="Tedarikçi seçimi, ürün satırları ve teslim planını adım adım hazırlayın."
                               Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0"/>
                </StackPanel>
                <UniformGrid Grid.Row="2" Columns="3">
                    <Border Style="{StaticResource StatusBadgeStyle}" Margin="0,0,10,0" Background="{StaticResource PrimaryLightBrush}">
                        <TextBlock Text="1  Tedarikçi" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                    </Border>
                    <Border Style="{StaticResource StatusBadgeStyle}" Margin="0,0,10,0" Background="{StaticResource MutedSurfaceBrush}">
                        <TextBlock Text="2  Ürünler" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold"/>
                    </Border>
                    <Border Style="{StaticResource StatusBadgeStyle}" Background="{StaticResource MutedSurfaceBrush}">
                        <TextBlock Text="3  Onay" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold"/>
                    </Border>
                </UniformGrid>
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <UniformGrid Columns="3">
                        <ComboBox ItemsSource="{Binding Suppliers}" SelectedValue="{Binding SupplierId, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="Name" Margin="0,0,12,0" ToolTip="Tedarikçi"/>
                        <DatePicker SelectedDate="{Binding OrderDate, Mode=TwoWay}" Margin="0,0,12,0" ToolTip="Sipariş tarihi"/>
                        <DatePicker SelectedDate="{Binding ExpectedDeliveryDate, Mode=TwoWay}" ToolTip="Beklenen teslim"/>
                    </UniformGrid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               VerticalAlignment="Center"/>
                    <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Vazgeç" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelCommand}" HorizontalAlignment="Left"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Geri" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding PreviousStepCommand}" Margin="0,0,10,0"/>
                        <Button Content="İleri" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding NextStepCommand}"/>
                    </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
