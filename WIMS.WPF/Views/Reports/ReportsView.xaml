<UserControl x:Class="WIMS.WPF.Views.Reports.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Rapor merkezi" Style="{StaticResource SubHeaderTextStyle}"/>
                    <TextBlock Text="Stok değeri, düşük stok ve hareket geçmişi raporlarını görüntüleyin ve Excel'e aktarın."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Excel aktar"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ExportToExcelCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Columns="3">
            <Border Style="{StaticResource PanelStyle}" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Stok değerleme" Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="Ürün bazında mevcut stok ve parasal değer analizi."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,8,0,18"/>
                    <Button Content="Raporu yükle"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LoadStockValuationCommand}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelStyle}" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Hareket geçmişi" Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="Belge numarası, ürün, tarih, miktar ve toplam değer."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,8,0,18"/>
                    <Button Content="Raporu yükle"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LoadMovementHistoryCommand}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="Düşük stok" Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="Kritik seviyeye düşen ürünlerin aksiyon listesi."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,8,0,18"/>
                    <Button Content="Raporu yükle"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LoadLowStockCommand}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="4" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding ReportTitle}" Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="{Binding ReportSummary}"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <DataGrid ItemsSource="{Binding StockValuationRows}"
                              Visibility="{Binding IsStockValuationSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="130"/>
                            <DataGridTextColumn Header="Ürün" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Kategori" Binding="{Binding CategoryName}" Width="150"/>
                            <DataGridTextColumn Header="Birim" Binding="{Binding UnitSymbol}" Width="90"/>
                            <DataGridTextColumn Header="Stok" Binding="{Binding CurrentStock}" Width="100"/>
                            <DataGridTextColumn Header="Birim fiyat" Binding="{Binding UnitPrice, StringFormat=N2}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid ItemsSource="{Binding MovementRows}"
                              Visibility="{Binding IsMovementHistorySelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding MovementDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Belge" Binding="{Binding DocumentNumber}" Width="140"/>
                            <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="90"/>
                            <DataGridTextColumn Header="Kod" Binding="{Binding ProductCode}" Width="130"/>
                            <DataGridTextColumn Header="Ürün" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Miktar" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Toplam" Binding="{Binding TotalPrice, StringFormat=N2}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid ItemsSource="{Binding LowStockRows}"
                              Visibility="{Binding IsLowStockSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="130"/>
                            <DataGridTextColumn Header="Ürün" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Stok" Binding="{Binding CurrentStock}" Width="100"/>
                            <DataGridTextColumn Header="Kritik seviye" Binding="{Binding ReorderPoint}" Width="120"/>
                            <DataGridTextColumn Header="Birim" Binding="{Binding UnitSymbol}" Width="80"/>
                            <DataGridTextColumn Header="Durum" Binding="{Binding StockStatus}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Style="{StaticResource EmptyStateStyle}"
                            Visibility="{Binding IsReportEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Rapor verisi bulunamadı" Style="{StaticResource EmptyStateTitleTextStyle}"/>
                            <TextBlock Text="Seçilen rapor için gösterilecek kayıt yok." Style="{StaticResource EmptyStateBodyTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource LoadingOverlayStyle}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Yükleniyor..." Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <Border Grid.Row="3"
                        Style="{StaticResource ErrorBannerStyle}"
                        Margin="0,12,0,0"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
