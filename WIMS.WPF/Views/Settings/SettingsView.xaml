<UserControl x:Class="WIMS.WPF.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelStyle}">
            <StackPanel>
                <TextBlock Text="Uygulama ayarları" Style="{StaticResource SubHeaderTextStyle}"/>
                <TextBlock Text="Firma bilgileri, veritabanı yedekleme ve geri yükleme işlemleri."
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Firma profili" Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBox Grid.Row="2" Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" ToolTip="Firma adı"/>
                    <TextBox Grid.Row="4" Text="{Binding CompanyPhone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" ToolTip="Telefon"/>
                    <TextBox Grid.Row="6" Text="{Binding CompanyEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" ToolTip="E-posta"/>
                    <Button Grid.Row="8"
                            Content="Ayarları kaydet"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveSettingsCommand}"
                            HorizontalAlignment="Left"/>
                    <Border Grid.RowSpan="9"
                            Style="{StaticResource LoadingOverlayStyle}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Yükleniyor..." Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="Veritabanı" Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="Yerel SQLite verisini düzenli olarak yedekleyin."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,8,0,18"/>
                    <Button Content="Yedek al"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BackupDatabaseCommand}"
                            Margin="0,0,0,10"/>
                    <Button Content="Yedekten dön"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RestoreDatabaseCommand}"/>
                    <Border Style="{StaticResource ErrorBannerStyle}"
                            Margin="0,16,0,0"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
