<UserControl x:Class="WIMS.WPF.Views.StockMovements.StockEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBackgroundBrush}">
    <Grid Margin="28">
        <Border Style="{StaticResource PanelStyle}" MaxWidth="760" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="Stok giriş / çıkış" Style="{StaticResource SubHeaderTextStyle}"/>
                    <TextBlock Text="Belge, ürün, miktar ve referans bilgisini kaydedin."
                               Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0"/>
                </StackPanel>
                <UniformGrid Grid.Row="2" Columns="2" Rows="3">
                    <TextBox Text="{Binding DocumentNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" Margin="0,0,12,12" ToolTip="Belge numarası"/>
                    <ComboBox ItemsSource="{Binding Products}" SelectedValue="{Binding ProductId, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="Name" Margin="0,0,0,12" ToolTip="Ürün"/>
                    <DatePicker SelectedDate="{Binding MovementDate, Mode=TwoWay}" Margin="0,0,12,12" ToolTip="Hareket tarihi"/>
                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" Margin="0,0,0,12" ToolTip="Miktar"/>
                    <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" Margin="0,0,12,0" ToolTip="Birim fiyat"/>
                    <TextBox Text="{Binding ReferenceNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" ToolTip="Referans"/>
                </UniformGrid>
                <TextBlock Grid.Row="3"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Vazgeç" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
                    <Button Content="Kaydet" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
