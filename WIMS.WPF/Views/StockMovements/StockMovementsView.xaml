<UserControl x:Class="WIMS.WPF.Views.StockMovements.StockMovementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Stok hareketleri" Style="{StaticResource SubHeaderTextStyle}"/>
                    <TextBlock Text="Giriş, çıkış ve transfer geçmişini tek ekrandan izleyin."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Stok girişi"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding NewInboundCommand}"
                        VerticalAlignment="Center"/>
                <Button Grid.Column="3"
                        Content="Stok çıkışı"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding NewOutboundCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Hareket geçmişi" Style="{StaticResource SectionTitleTextStyle}"/>
                    <Button Grid.Column="1"
                            Content="Excel aktar"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ExportHistoryCommand}"/>
                </Grid>
                <Grid Grid.Row="2">
                    <DataGrid ItemsSource="{Binding Movements}"
                              Visibility="{Binding HasMovements, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding MovementDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Belge no" Binding="{Binding DocumentNumber}" Width="130"/>
                            <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="100"/>
                            <DataGridTextColumn Header="Ürün" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Miktar" Binding="{Binding Quantity}" Width="110"/>
                            <DataGridTextColumn Header="Birim fiyat" Binding="{Binding UnitPrice, StringFormat=N2}" Width="120"/>
                            <DataGridTextColumn Header="Referans" Binding="{Binding ReferenceNumber}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Style="{StaticResource EmptyStateStyle}"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Stok hareketi bulunamadı" Style="{StaticResource EmptyStateTitleTextStyle}"/>
                            <TextBlock Text="İlk hareketi stok girişi veya çıkışı olarak oluşturun." Style="{StaticResource EmptyStateBodyTextStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource LoadingOverlayStyle}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Yükleniyor..." Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource ErrorBannerStyle}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
