<UserControl x:Class="WIMS.WPF.Views.Suppliers.SuppliersDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBackgroundBrush}">
    <Grid Margin="28">
        <Border Style="{StaticResource PanelStyle}" MaxWidth="760" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="Tedarikçi detayı" Style="{StaticResource SubHeaderTextStyle}"/>
                    <TextBlock Text="Satın alma ve iletişim bilgilerini eksiksiz tutun."
                               Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0"/>
                </StackPanel>
                <UniformGrid Grid.Row="2" Columns="2" Rows="3">
                    <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" Margin="0,0,12,12" ToolTip="Tedarikçi kodu"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" Margin="0,0,0,12" ToolTip="Tedarikçi adı"/>
                    <TextBox Text="{Binding ContactName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" Margin="0,0,12,12" ToolTip="Yetkili kişi"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" Margin="0,0,0,12" ToolTip="Telefon"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" Margin="0,0,12,0" ToolTip="E-posta"/>
                    <TextBox Text="{Binding TaxNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StandardTextBoxStyle}" ToolTip="Vergi numarası"/>
                </UniformGrid>
                <TextBlock Grid.Row="3"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Vazgeç" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
                    <Button Content="Kaydet" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
